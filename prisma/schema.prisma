// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Position {
  GK
  DEF
  MID
  ATT
}

enum Form {
  hot
  normal
  cold
}

model Player {
  id         String   @id @default(uuid())
  name       String
  team       String
  position   Position
  price      Int
  rating     Int
  image      String
  form       Form
  attributes Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("players")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}